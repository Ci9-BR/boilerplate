{
  "name": "boilerplate",
  "version": "1.0.0",
  "description": "Professional NestJS backend boilerplate",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "rimraf dist && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "stop": "docker-compose down",
    "infra": "docker-compose up -d",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test:unit": "jest --config jest-unit.json --passWithNoTests",
    "test:integrated": "jest --config jest-int.json --passWithNoTests",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "keywords": [],
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/client-sns": "^3.1005.0",
    "@aws-sdk/client-sqs": "^3.1005.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.0.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/swagger": "^11.2.6",
    "@playwright/test": "^1.58.2",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-sonarjs": "^4.0.1",
    "husky": "^9.1.7",
    "i18next": "^25.8.17",
    "i18next-fs-backend": "^2.6.1",
    "lint-staged": "^16.3.2",
    "nodemailer": "^8.0.2",
    "playwright": "^1.58.2",
    "prisma": "^6.4.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1005.0",
    "@aws-sdk/client-secrets-manager": "^3.1005.0",
    "@prisma/client": "^6.4.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "openai": "^6.27.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "@nestjs/cli": {
      "ajv": "^8.18.0"
    },
    "@nestjs/schematics": {
      "ajv": "^8.18.0"
    },
    "html-minifier": {
      "ajv": "^8.18.0"
    },
    "glob": "^10.5.0",
    "tar": "^7.5.10",
    "minimatch": "^10.2.4"
  }
}